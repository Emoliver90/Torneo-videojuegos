# Copia este archivo como ".env" y completa tus propios valores.
# El archivo ".env" real NUNCA debe subirse al repositorio (ya está en .gitignore).

# Clave secreta de Django. Genera una nueva con:
# python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=cambia-esto-por-una-clave-secreta-unica

# True solo en desarrollo local. En producción debe ser False.
DEBUG=True

# Hosts permitidos, separados por coma. En producción incluye tu dominio real.
ALLOWED_HOSTS=localhost,127.0.0.1
